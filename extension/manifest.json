{
  "manifest_version": 3,
  "name": "PhishDetect Pro",
  "version": "3.0",
  "description": "Real-time phishing detection using Hybrid ML + Rules.",
  "permissions": [
    "tabs",
    "activeTab",
    "contextMenus"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PhishDetect Pro"
  },
  "icons": {
    "32": "icons/favicon-32x32.png",
    "16": "icons/favicon-16x16.png",
    "156": "icons/android-chrome.png"
  }
}